{
  "manifest_version": 3,
  "name": "YT Audio Only",
  "version": "1.0.3",
  "description": "Toggles audio-only playback on YouTube.",
  "icons": {
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "64": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "declarativeNetRequest"
  ],
  "background": {
    "scripts": [
      "background/main.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://youtube.com/*",
        "*://www.youtube.com/*"
      ],
      "js": [
        "content/page-visibility.js"
      ],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": [
        "*://youtube.com/*",
        "*://www.youtube.com/*"
      ],
      "js": [
        "content/config.js",
        "content/state.js",
        "content/utils.js",
        "content/anti-interrupt.js",
        "content/api.js",
        "content/prefetch.js",
        "content/player.js",
        "content/ui.js",
        "content/main.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-audio-onlyy@mustafachyi.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}